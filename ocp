}

# :command.function
ocp_launch_command() {

  # src/launch_command.sh
  p="$(ocp_resolve_profile "${args[--profile]:-}" "$PWD" 2>/dev/null || true)"

  pass=()
  if [ "${other_args[*]:-}" != "" ]; then
    pass=("${other_args[@]}")
  fi

  if [ -z "$p" ]; then
    if [ -n "${args[--print]}" ]; then
      printf 'exec'
      printf ' %q' opencode "${pass[@]}"
      printf '\n'
      exit 0
    fi
    exec opencode "${pass[@]}"
  fi

  ocp_profile_exists "$p" || ocp_die "Profile '$p' does not exist. Create it with: ocp create $p"

  cfg="$(ocp_config_dir "$p")"
  data="$(ocp_data_dir "$p")"
  envf="$(ocp_env_file "$p")"
  ocp_load_manifest "$p"

  cmd=(opencode)
  if [ -n "${DEFAULT_ARGS:-}" ]; then
    # shellcheck disable=SC2206
    cmd+=($DEFAULT_ARGS)
  fi
  cmd+=("${pass[@]}")

  if [ -n "${WRAPPER:-}" ]; then
    w="$WRAPPER"
    w="${w//\{profile_dir\}/$(ocp_profile_dir "$p")}"
    w="${w//\{config_dir\}/$cfg}"
    w="${w//\{data_dir\}/$data}"
    read -ra wrap <<<"$w"
    cmd=("${wrap[@]}" "${cmd[@]}")
  fi

  if [ -n "${args[--print]}" ]; then
    printf 'OPENCODE_CONFIG_DIR=%s\n' "$cfg"
    printf 'XDG_DATA_HOME=%s\n' "$data"
    [ -f "$envf" ] && printf 'env-file: %s\n' "$envf"
    printf 'exec'
    printf ' %q' "${cmd[@]}"
    printf '\n'
    exit 0
  fi

  if [ -f "$envf" ]; then
    set -a
    # shellcheck disable=SC1090
    . "$envf"
    set +a
  fi

  exec env OPENCODE_CONFIG_DIR="$cfg" XDG_DATA_HOME="$data" "${cmd[@]}"

}

# :command.function
ocp_pin_command() {

  # src/pin_command.sh
  name="${args[name]}"
  ocp_validate_name "$name"

  dir="${args[dir]:-$PWD}"
  dir="$(ocp_expand "$dir")"
  [ -d "$dir" ] || ocp_die "Directory not found: $dir"

  ocp_profile_exists "$name" || ocp_warn "Profile '$name' does not exist yet (create it with: ocp create $name)."

  printf '%s\n' "$name" >"$dir/.ocprofile" || ocp_die "Failed to write .ocprofile"
  ocp_info "Pinned '$name' in $dir/.ocprofile"

}

# :command.function
ocp_edit_command() {

  # src/edit_command.sh
  name="${args[name]}"
  what="${args[--what]:-config}"
  ocp_profile_exists "$name" || ocp_die "Profile '$name' does not exist."

  pdir="$(ocp_profile_dir "$name")"
  case "$what" in
    config) target="$pdir/config" ;;
    manifest) target="$(ocp_manifest "$name")" ;;
    opencode-json) target="$pdir/config/opencode.json" ;;
    omo) target="$pdir/config/oh-my-openagent.json" ;;
    env) target="$(ocp_env_file "$name")" ;;
    data) target="$pdir/data/opencode" ;;
    *) ocp_die "Unknown --what target: $what" ;;
  esac

  ed="${VISUAL:-${EDITOR:-}}"
  if [ -z "$ed" ]; then
    ocp_info "$target"
    ocp_die "No \$EDITOR/\$VISUAL set; path printed above."
  fi

  exec "$ed" "$target"

}

# :command.function
ocp_path_command() {

  # src/path_command.sh
  name="${args[name]}"
  ocp_profile_exists "$name" || ocp_die "Profile '$name' does not exist."
  printf 'profile : %s\n' "$name"
  printf 'root    : %s\n' "$(ocp_profile_dir "$name")"
  printf 'config  : %s\n' "$(ocp_config_dir "$name")"
  printf 'data    : %s\n' "$(ocp_data_dir "$name")"

}

# :command.function
ocp_remove_command() {

  # src/remove_command.sh
  name="${args[name]}"
  ocp_validate_name "$name"
  ocp_profile_exists "$name" || ocp_die "Profile '$name' does not exist."

  pdir="$(ocp_profile_dir "$name")"

  if [ -d "$pdir/data" ] && [ -z "${args[--purge-data]}" ]; then
    ocp_die "Profile '$name' has data (auth/sessions) at $pdir/data. Re-run with --purge-data to delete everything, or back it up first."
  fi

  if [ -z "${args[--yes]}" ]; then
    printf "Remove profile '%s' at %s (INCLUDING data/auth/sessions)? [y/N]: " "$name" "$pdir"
    IFS= read -r ans || ans=""
    case "$ans" in
      y | Y | yes) ;;
      *)
        ocp_info "Aborted."
        exit 0
        ;;
    esac
  fi

  rm -rf "$pdir" || ocp_die "Failed to remove $pdir"
  ocp_info "Removed profile '$name'."

  active=""
  ocp_active_profile >/dev/null && active="$(ocp_active_profile)"
  if [ "$name" = "$active" ]; then
    rm -f "$(ocp_active_file)"
    ocp_warn "Removed the active default; set a new one with 'ocp use <name>'."
  fi

}

# :command.function
ocp_init_shell_command() {

  # src/init_shell_command.sh
  cmd="${args[--command]:-opencode}"

  printf '# >>> ocp shell integration >>>\n'
  printf '%s() { command ocp launch -- "$@"; }\n' "$cmd"

  if [ -z "${args[--no-chpwd]}" ]; then
    printf '_ocp_chpwd() { export OCP_ACTIVE_PROFILE="$(command ocp resolve --quiet 2>/dev/null)"; }\n'
    printf 'autoload -Uz add-zsh-hook 2>/dev/null && add-zsh-hook chpwd _ocp_chpwd\n'
    printf '_ocp_chpwd\n'
  fi

  if [ -n "${args[--per-profile-aliases]}" ]; then
    root="$(ocp_profiles_dir)"
    if [ -d "$root" ]; then
      for d in "$root"/*/; do
        [ -d "$d" ] || continue
        n="$(basename "$d")"
        printf '%s-%s() { command ocp launch -p %s -- "$@"; }\n' "$cmd" "$n" "$n"
      done
    fi
  fi

  printf '# <<< ocp shell integration <<<\n'

}

# :command.parse_requirements
parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        ocp_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.environment_variables_filter

  env_var_names+=("OCP_HOME")
  env_var_names+=("OCP_PROFILE")

  # :command.command_filter
  action=${1:-}

  case $action in
    -*) ;;

    create | new)
      action="create"
      shift
      ocp_create_parse_requirements "$@"
      shift $#
      ;;

    list | ls)
      action="list"
      shift
      ocp_list_parse_requirements "$@"
      shift $#
      ;;

    current)
      action="current"
      shift
      ocp_current_parse_requirements "$@"
      shift $#
      ;;

    resolve)
      action="resolve"
      shift
      ocp_resolve_parse_requirements "$@"
      shift $#
      ;;

    use | default)
      action="use"
      shift
      ocp_use_parse_requirements "$@"
      shift $#
      ;;

    launch | run)
      action="launch"
      shift
      ocp_launch_parse_requirements "$@"
      shift $#
      ;;

    pin)
      action="pin"
      shift
      ocp_pin_parse_requirements "$@"
      shift $#
      ;;

    edit)
      action="edit"
      shift
      ocp_edit_parse_requirements "$@"
      shift $#
      ;;

    path)
      action="path"
      shift
      ocp_path_parse_requirements "$@"
      shift $#
      ;;

    remove | rm)
      action="remove"
      shift
      ocp_remove_parse_requirements "$@"
      shift $#
      ;;

    init-shell)
      action="init-shell"
      shift
      ocp_init_shell_parse_requirements "$@"
      shift $#
      ;;

    # :command.command_fallback
    "")
      ocp_usage >&2
      exit 1
      ;;

    *)
      printf "invalid command: %s\n" "$action" >&2
      exit 1
      ;;

  esac

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

